// src/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id             String    @id @default(cuid())
  name           String
  owner_admin_id String?
  plan           String    @default("basic")
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  users     User[]
  leads     Lead[]
  deals     Deal[]
  contacts  Contact[]
  tasks     Task[]
  messages  Message[]
  pipelines Pipeline[]
  stages    Stage[]
  settings  Setting[]

  @@map("companies")
}

model User {
  id            String   @id @default(cuid())
  company_id    String
  name          String
  email         String   @unique
  password_hash String
  role          Role     @default(manager)
  status        Status   @default(active)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  company          Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  assigned_leads   Lead[]   @relation("AssignedLeads")
  assigned_deals   Deal[]   @relation("AssignedDeals")
  assigned_tasks   Task[]   @relation("AssignedTasks")

  @@map("users")
}

model Lead {
  id                  String   @id @default(cuid())
  company_id          String
  assigned_manager_id String?
  name                String
  phone               String?
  email               String?
  source              String?
  status              String   @default("new")
  stage_id            String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  company          Company   @relation(fields: [company_id], references: [id], onDelete: Cascade)
  assigned_manager User?     @relation("AssignedLeads", fields: [assigned_manager_id], references: [id], onDelete: SetNull)
  stage            Stage?    @relation(fields: [stage_id], references: [id], onDelete: SetNull)
  deals            Deal[]
  contacts         Contact[]
  tasks            Task[]
  messages         Message[]

  @@map("leads")
}

model Deal {
  id                  String   @id @default(cuid())
  company_id          String
  lead_id             String?
  assigned_manager_id String?
  title               String
  amount              Float    @default(0)
  stage_id            String?
  status              String   @default("open")
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  company          Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  lead             Lead?   @relation(fields: [lead_id], references: [id], onDelete: SetNull)
  assigned_manager User?   @relation("AssignedDeals", fields: [assigned_manager_id], references: [id], onDelete: SetNull)
  stage            Stage?  @relation(fields: [stage_id], references: [id], onDelete: SetNull)
  tasks            Task[]

  @@map("deals")
}

model Contact {
  id         String   @id @default(cuid())
  company_id String
  lead_id    String?
  name       String
  phone      String?
  email      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  lead    Lead?   @relation(fields: [lead_id], references: [id], onDelete: SetNull)

  @@map("contacts")
}

model Task {
  id                  String     @id @default(cuid())
  company_id          String
  lead_id             String?
  deal_id             String?
  assigned_manager_id String?
  title               String
  description         String?
  deadline            DateTime?
  status              TaskStatus @default(todo)
  created_at          DateTime   @default(now())
  updated_at          DateTime   @updatedAt

  company          Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  lead             Lead?   @relation(fields: [lead_id], references: [id], onDelete: SetNull)
  deal             Deal?   @relation(fields: [deal_id], references: [id], onDelete: SetNull)
  assigned_manager User?   @relation("AssignedTasks", fields: [assigned_manager_id], references: [id], onDelete: SetNull)

  @@map("tasks")
}

model Message {
  id          String      @id @default(cuid())
  company_id  String
  lead_id     String
  sender_type SenderType
  text        String
  created_at  DateTime    @default(now())

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  lead    Lead    @relation(fields: [lead_id], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Pipeline {
  id         String   @id @default(cuid())
  company_id String
  name       String
  created_at DateTime @default(now())

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  stages  Stage[]

  @@map("pipelines")
}

model Stage {
  id          String   @id @default(cuid())
  company_id  String
  pipeline_id String
  name        String
  color       String   @default("#4f8ef7")
  position    Int      @default(0)
  created_at  DateTime @default(now())

  company  Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  pipeline Pipeline @relation(fields: [pipeline_id], references: [id], onDelete: Cascade)
  leads    Lead[]
  deals    Deal[]

  @@map("stages")
}

model Setting {
  id         String   @id @default(cuid())
  company_id String
  key        String
  value      String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@unique([company_id, key])
  @@map("settings")
}

enum Role {
  admin
  manager
}

enum Status {
  active
  inactive
}

enum TaskStatus {
  todo
  done
  overdue
}

enum SenderType {
  client
  manager
}
